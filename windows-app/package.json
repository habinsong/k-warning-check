{
  "name": "@k-warning-check/windows-app",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "build": {
    "appId": "kr.k_warning_check.desktop.windows",
    "productName": "K-WarningCheck Desktop",
    "electronVersion": "37.2.6",
    "directories": {
      "app": ".app-build",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "electron-shared/**/*",
      "renderer/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "asar": true,
    "electronLanguages": ["ko", "en-US"],
    "artifactName": "K-WarningCheck-Desktop-Windows-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
